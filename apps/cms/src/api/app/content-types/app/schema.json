{
  "kind": "collectionType",
  "collectionName": "apps",
  "info": {
    "singularName": "app",
    "pluralName": "apps",
    "displayName": "App",
    "description": "Screen mirroring and TV remote applications"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 100
    },
    "displayTitle": {
      "type": "string"
    },
    "sections": {
      "type": "dynamiczone",
      "components": [
        "sections.hero",
        "sections.why-choose",
        "sections.feature-highlight",
        "sections.statistics",
        "sections.reviews",
        "sections.cta",
        "sections.apps-grid",
        "sections.brands-grid"
      ]
    },
    "downloadLinks": {
      "type": "component",
      "repeatable": true,
      "component": "shared.download-link"
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "enum": ["screen-mirroring", "tv-remote"],
      "required": true
    },
    "shortDescription": {
      "type": "string",
      "maxLength": 255
    },
    "description": {
      "type": "blocks"
    },
    "icon": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "screenshots": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "heroImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "downloadCount": {
      "type": "string"
    },
    "rating": {
      "type": "decimal",
      "min": 0,
      "max": 5
    },
    "features": {
      "type": "component",
      "repeatable": true,
      "component": "shared.feature"
    },
    "supportedDevices": {
      "type": "json"
    },
    "targetBrands": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::device-brand.device-brand",
      "mappedBy": "apps"
    },
    "tutorials": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::tutorial.tutorial",
      "mappedBy": "app"
    },
    "faqs": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::faq.faq",
      "mappedBy": "app"
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "isFeatured": {
      "type": "boolean",
      "default": false
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}

