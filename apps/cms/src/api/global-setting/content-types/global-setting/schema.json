{
  "kind": "singleType",
  "collectionName": "global_settings",
  "info": {
    "singularName": "global-setting",
    "pluralName": "global-settings",
    "displayName": "Global Settings"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "siteName": {
      "type": "string",
      "required": true
    },
    "siteDescription": {
      "type": "text"
    },
    "googlePlayBadge": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "appStoreBadge": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "footerLogo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "favicon": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "contactEmail": {
      "type": "email"
    },
    "supportEmail": {
      "type": "email"
    },
    "socialLinks": {
      "type": "component",
      "component": "shared.social-link",
      "repeatable": true
    },
    "footerText": {
      "type": "text"
    },
    "trademarkDisclaimer": {
      "type": "text"
    },
    "tryForFreeText": {
      "type": "string"
    },
    "tryForFreeLink": {
      "type": "string"
    },
    "tocTitle": {
      "type": "string"
    },
    "relatedPostsTitle": {
      "type": "string"
    },
    "appStoreRateLabel": {
      "type": "string",
      "default": "Decent App Store Rate:"
    },
    "statistics": {
      "type": "component",
      "component": "shared.statistics",
      "repeatable": false
    },
    "defaultSeo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false
    }
  }
}
